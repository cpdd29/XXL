POSTGRES_DB=workbot
POSTGRES_USER=workbot
POSTGRES_PASSWORD=workbot
POSTGRES_PORT=5432

REDIS_PORT=6379

NATS_PORT=4222
NATS_MONITOR_PORT=8222

CHROMA_PORT=8000

BACKEND_PORT=8080
FRONTEND_PORT=3000

NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8080

WORKBOT_ENVIRONMENT=docker-compose
WORKBOT_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
WORKBOT_MESSAGE_RATE_LIMIT_PER_MINUTE=5
WORKBOT_MESSAGE_DEBOUNCE_SECONDS=3
WORKBOT_MEMORY_RETRIEVE_LIMIT=5
WORKBOT_METRICS_SCRAPE_TOKEN=
WORKBOT_TOOL_SOURCES_MODE=external_only
WORKBOT_ENABLE_LOCAL_MCP_SOURCE=false
WORKBOT_ENABLE_LOCAL_AGENT_SOURCE=false
WORKBOT_EXTERNAL_TOOL_SOURCES_FILE=/opt/workbot/external-registry/workbot_external_sources.local.json
WORKBOT_EXTERNAL_REGISTRY_SOURCE_FILE=../XXL_ExternalConnection/config/workbot_external_sources.combined.json
WORKBOT_SEARCH_MCP_BASE_URL=http://host.docker.internal:8093
WORKBOT_PDF_MCP_BASE_URL=http://host.docker.internal:8092
WORKBOT_WRITER_MCP_BASE_URL=http://host.docker.internal:8094
WORKBOT_WEATHER_MCP_BASE_URL=http://host.docker.internal:8095
WORKBOT_ORDER_MCP_BASE_URL=http://host.docker.internal:8096
WORKBOT_CRM_MCP_BASE_URL=http://host.docker.internal:8097
WORKBOT_MEMORY_SESSION_IDLE_SECONDS=900
WORKBOT_INTERNAL_EVENT_RETRY_POLL_INTERVAL_SECONDS=5
WORKBOT_INTERNAL_EVENT_RETRY_BACKOFF_SECONDS=15
WORKBOT_INTERNAL_EVENT_RETRY_LEASE_SECONDS=60
WORKBOT_INTERNAL_EVENT_RETRY_SCAN_LIMIT=20
WORKBOT_MEMORY_SQLITE_PATH=data/memory-midterm.sqlite3
WORKBOT_CHROMA_COLLECTION_NAME=workbot_long_term_memory
WORKBOT_TELEGRAM_BOT_TOKEN=
WORKBOT_TELEGRAM_WEBHOOK_SECRET=
WORKBOT_TELEGRAM_API_BASE_URL=https://api.telegram.org
WORKBOT_DINGTALK_APP_ID=
WORKBOT_DINGTALK_AGENT_ID=
WORKBOT_DINGTALK_CLIENT_ID=
WORKBOT_DINGTALK_CLIENT_SECRET=
WORKBOT_DINGTALK_CORP_ID=
WORKBOT_DINGTALK_API_BASE_URL=https://oapi.dingtalk.com
